<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OSC"
                android:textSize="56sp"
                android:textColor="#FFBB86FC"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Player"
                android:textSize="22sp"
                android:textColor="#FFBB86FC"
                android:alpha="0.7"
                android:letterSpacing="0.3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v2.0"
                android:textSize="14sp"
                android:textColor="#66FFFFFF"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="展览展示 / 数字标牌播放器"
                android:textSize="13sp"
                android:textColor="#44FFFFFF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Network Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="网络信息"
                android:textSize="11sp"
                android:textColor="#FFBB86FC"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="端口"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/aboutPort"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8000"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="IP地址"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/aboutIP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="获取中..."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="协议"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OSC (UDP)"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- System Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="系统信息"
                android:textSize="11sp"
                android:textColor="#FFBB86FC"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="引擎"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Media3 (ExoPlayer)"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="解码"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="硬解加速 + 软解回退"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="目录"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="/storage/emulated/0/Movies"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Features Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="核心功能"
                android:textSize="11sp"
                android:textColor="#FFBB86FC"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&#x2022; OSC 远程控制 (UDP 端口 8000)"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&#x2022; 播放列表 / 循环 / 定时开关"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&#x2022; 播放速度 / 字幕 / 文字叠加"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&#x2022; 截图 / 文件管理 / USB 拷贝"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&#x2022; 看门狗自动恢复 / 开机自启"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- OSC Commands Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OSC 命令参考"
                android:textSize="11sp"
                android:textColor="#FFBB86FC"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/aboutCommands"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="加载中..."
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developed by YHC"
                android:textSize="12sp"
                android:textColor="#44FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by opencode"
                android:textSize="11sp"
                android:textColor="#33FFFFFF"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
