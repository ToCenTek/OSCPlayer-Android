<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FF1A1A1A"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/aboutLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/logo" />

            <TextView
                android:id="@+id/aboutTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OSC Video Player"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/aboutSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v2.0  |  展览展示  |  数字标牌"
                android:textSize="12sp"
                android:textColor="#66FFFFFF"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Network Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="网络信息"
                android:textSize="11sp"
                android:textColor="#FF2FA1D3"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="端口"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/aboutPort"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8000"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="地址"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/aboutIP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="获取中..."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="协议"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OSC (UDP)  /  HTTP"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- System Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="系统信息"
                android:textSize="11sp"
                android:textColor="#FF2FA1D3"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="引擎"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Media3 (ExoPlayer)"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="解码"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="硬解加速 + 软解回退"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="目录"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="/storage/emulated/0/Movies"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Features Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1A1A1A"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="核心功能"
                android:textSize="11sp"
                android:textColor="#FF2FA1D3"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  OSC 远程控制 (UDP 8000 / HTTP 8080)"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  播放列表 / 循环 / 定时开关"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  播放速度 / 字幕 / 文字叠加"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  截图 / 文件管理 / USB 拷贝"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:paddingBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  看门狗自动恢复 / 开机自启"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  更多功能详见 README.md"
                android:textColor="#55FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="8dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developed by YHC"
                android:textSize="12sp"
                android:textColor="#44FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by opencode"
                android:textSize="11sp"
                android:textColor="#33FFFFFF"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
